# justfile

# load environment variables
set dotenv-load

# variables

# aliases
alias fmt:=format
alias install:=sync

# list justfile recipes
default:
    just --list

# python things
setup:
    @uv venv --python=3.12 --allow-existing
    just sync

sync:
    @uv sync --all-extras --upgrade

install-core:
    @uv pip install $HOME/code/ascend-io/core

build-python:
    @rm -r dist || true
    @uv build

format:
    @ruff format .

# preview
preview:
    quarto preview website

# build
build:
    quarto render website

# cloud stuff
# TODO: azcopy or Python code; or ideally Ascend
upload-az:
    @az storage blob upload-batch --account-name codyascend -d "cody-public" -s data --overwrite


upload-gs:
    @gsutil -m rsync -r data gs://ascend-io-gcs-public/lakev0

upload-gs-test:
    @gsutil -m rsync -r datatest gs://ascend-io-gcs-public/lakev0test

# clean
clean-data:
    @rm -rf data
    @mkdir -p data

clean:
    rm -rf website/_site
    rm -rf website/_freeze
    rm -rf website/.quarto

