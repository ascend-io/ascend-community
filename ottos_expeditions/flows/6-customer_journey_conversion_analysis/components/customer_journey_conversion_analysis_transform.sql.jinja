WITH customer_journey AS (
    SELECT
        wt.customer_id,
        wt.session_id,
        wt.visit_date,
        wt.page_visited,
        wt.traffic_source,
        wt.device_type,
        wt.session_duration,
        wt.conversion,
        o.order_id,
        o.order_date,
        o.order_amount
    FROM
        {{ ref('web_traffic') }} wt
    LEFT JOIN
        {{ ref('orders') }} o ON wt.customer_id = o.customer_id AND wt.visit_date = o.order_date
),
conversion_analysis AS (
    SELECT
        cj.traffic_source,
        cj.page_visited,
        COUNT(cj.session_id) AS total_sessions,
        SUM(CASE WHEN cj.conversion = TRUE THEN 1 ELSE 0 END) AS total_conversions,
        ROUND(SUM(CASE WHEN cj.conversion = TRUE THEN 1 ELSE 0 END) * 100.0 / COUNT(cj.session_id), 2) AS conversion_rate,
        AVG(cj.session_duration) AS avg_session_duration,
        SUM(cj.order_amount) AS total_revenue
    FROM
        customer_journey cj
    GROUP BY
        cj.traffic_source, cj.page_visited
)
SELECT
    traffic_source,
    page_visited,
    total_sessions,
    total_conversions,
    conversion_rate,
    avg_session_duration,
    total_revenue
FROM
    conversion_analysis
ORDER BY
    conversion_rate DESC;
