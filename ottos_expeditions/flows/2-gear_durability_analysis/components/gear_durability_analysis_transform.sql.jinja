SELECT 
    r.route_name,
    r.difficulty_level,
    g.gear_type,
    COUNT(g.rental_id) AS total_rentals,
    ROUND(SUM(CASE WHEN g.condition_after = 'Damaged' THEN 1 ELSE 0 END) * 100.0 / COUNT(g.rental_id), 2) AS damage_rate
FROM 
    expeditions e
JOIN 
    routes r ON e.route_id = r.route_id
JOIN 
    gear_rentals g ON e.expedition_id = g.expedition_id
GROUP BY 
    r.route_name, r.difficulty_level, g.gear_type
ORDER BY 
    damage_rate DESC;